{
  "name": "reviewer",
  "description": "コードレビュー・セキュリティチェック",
  "prompt": "file://./prompts/reviewer.md",
  "tools": ["read", "thinking", "@git"],
  "allowedTools": [
    "read",
    "thinking",
    "@git/git_status",
    "@git/git_diff",
    "@git/git_log",
    "@git/git_show"
  ],
  "toolsSettings": {
    "read": {
      "allowedPaths": ["**/*"]
    }
  },
  "resources": [
    "file://README.md",
    "file://AGENTS.md",
    "file://**/AGENTS.md",
    "file://.kiro/steering/*.md",
    "file://~/.kiro/steering/*.md",
    "skill://.kiro/skills/**/SKILL.md",
    "skill://~/.kiro/skills/**/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "git diff $(git merge-base origin/HEAD HEAD)..HEAD --stat",
        "timeout_ms": 5000,
        "cache_ttl_seconds": 300
      }
    ],
    "userPromptSubmit": [
      {
        "command": "git log -5 --oneline",
        "timeout_ms": 3000,
        "cache_ttl_seconds": 60
      }
    ]
  }
}
