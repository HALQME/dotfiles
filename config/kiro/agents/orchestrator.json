{
  "name": "orchestrator",
  "description": "Coordinates specialized subagents for complex tasks - research, code review, refactoring, documentation",
  "prompt": "file://./prompts/orchestrator.md",
  "tools": ["read", "subagent", "execute_bash"],
  "allowedTools": ["read", "subagent", "execute_bash"],
  "toolsSettings": {
    "subagent": {
      "availableAgents": ["reviewer", "refactor", "editor", "docs-*"],
      "trustedAgents": ["reviewer", "refactor", "editor"]
    },
    "execute_bash": {
      "allowedCommands": ["ls", "cat", "head", "tail", "git status", "git diff", "git log -5 --oneline"],
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://README.md",
    "file://AGENTS.md",
    "file://**/AGENTS.md",
    "file://.kiro/steering/*.md",
    "file://~/.kiro/steering/*.md",
    "skill://.kiro/skills/**/SKILL.md",
    "skill://~/.kiro/skills/**/SKILL.md"
  ],
  "hooks": {}
}
