{
  "name": "orchestrator",
  "description": "Coordinates specialized subagents for complex tasks - research, code review, refactoring, documentation",
  "prompt": "file://./prompts/orchestrator.md",
  "tools": ["read", "write", "shell", "subagent"],
  "allowedTools": ["read", "write"],
  "toolsSettings": {
    "subagent": {
      "availableAgents": ["reviewer", "refactor", "editor", "docs-*"],
      "trustedAgents": ["reviewer", "refactor"]
    }
  },
  "resources": [
    "file://../steering/**/*.md",
    "skill://../skills/**/SKILL.md"
  ],
  "model": "claude-sonnet-4.6"
}
