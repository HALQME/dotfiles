{
  "name": "editor",
  "description": "新規コード生成とファイル編集 - 機能実装、プロトタイプ作成、コード生成",
  "prompt": "file://./prompts/editor.md",
  "tools": ["read", "write", "thinking", "@git", "execute_bash"],
  "toolAliases": {
    "@git/git_status": "status",
    "@git/git_commit": "commit"
  },
  "allowedTools": [
    "read",
    "thinking",
    "@git/git_status",
    "@git/git_diff",
    "@git/git_log",
    "write",
    "execute_bash"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "src/**", "lib/**", "app/**", "components/**", "utils/**",
        "tests/**", "*.md", "*.json", "*.yml", "*.yaml",
        "*.js", "*.ts", "*.py", "*.go", "*.rs", "docs/**"
      ]
    },
    "execute_bash": {
      "allowedCommands": ["git status", "git diff"],
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://README.md",
    "file://AGENTS.md",
    "file://**/AGENTS.md",
    "file://.kiro/steering/*.md",
    "file://~/.kiro/steering/*.md",
    "skill://.kiro/skills/**/SKILL.md",
    "skill://~/.kiro/skills/**/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "git status --porcelain",
        "timeout_ms": 5000,
        "cache_ttl_seconds": 60
      }
    ]
  }
}
