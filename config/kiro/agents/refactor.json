{
  "name": "refactor",
  "description": "コードリファクタリング専門 - 既存コード改善、ドキュメント、テスト生成",
  "prompt": "file://./prompts/refactor.md",
  "tools": ["read", "write", "thinking", "@git", "execute_bash"],
  "toolAliases": {
    "@git/git_status": "status",
    "@git/git_commit": "commit"
  },
  "allowedTools": [
    "read",
    "thinking",
    "@git/git_status",
    "@git/git_diff",
    "@git/git_log",
    "write",
    "execute_bash"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": ["src/**", "tests/**", "*.md", "*.json", "*.yml", "*.yaml", "docs/**"]
    },
    "execute_bash": {
      "allowedCommands": [
        "git status",
        "git diff",
        "mise run lint",
        "mise run format",
        "mise run type-check",
        "mise run test"
      ],
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://README.md",
    "file://AGENTS.md",
    "file://**/AGENTS.md",
    "file://.kiro/steering/*.md",
    "file://~/.kiro/steering/*.md",
    "skill://.kiro/skills/**/SKILL.md",
    "skill://~/.kiro/skills/**/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "git status --porcelain",
        "timeout_ms": 5000,
        "cache_ttl_seconds": 60
      }
    ]
  }
}
