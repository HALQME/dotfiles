{
  "ai.terminal-hash-sub": false,
  "autocomplete.disable": false,
  "autocomplete.firstTokenCompletion": true,
  "autocomplete.fontFamily": "Moralerspace Radon",
  "autocomplete.fuzzySearch": true,
  "autocomplete.immediatelyExecuteAfterSpace": true,
  "autocomplete.onlyShowOnTab": true,
  "autocomplete.theme": "system",
  "chat.defaultAgent": "orchestrator",
  "chat.defaultModel": "minimax-m2.1",
  "chat.enableCheckpoint": true,
  "chat.enableDelegate": true,
  "chat.enableKnowledge": true,
  "chat.enableTangentMode": true,
  "chat.enableThinking": true,
  "chat.enableTodoList": true,
  "chat.greeting.enabled": false,
  "codeWhisperer.shareCodeWhispererContentWithAWS": false,
  "mcp.loadedBefore": true,
  "telemetry.enabled": false
}
